# EMLinteractive — environment variables
#
# Copy this file to `.env.local` if you need to override defaults during
# local development. `.env.local` is gitignored.
#
# This is a static, fully client-side app. No secrets are required to run it.

# Absolute base URL used by Next.js metadata, sitemap, and robots.txt.
# Falls back to the deployed GitHub Pages URL when unset.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "true" when building for GitHub Pages so Next.js applies the
# `/emlinteractive` basePath and assetPrefix. Leave unset for local dev,
# Vercel, or any host that serves the app at the root path.
# GITHUB_PAGES=false
